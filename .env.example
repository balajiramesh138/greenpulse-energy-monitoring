# Database (TimescaleDB)
DATABASE_URL="postgresql://greenpulse:greenpulse123@localhost:5432/greenpulse?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# InfluxDB (optional)
INFLUXDB_URL="http://localhost:8086"
INFLUXDB_TOKEN="your-influxdb-token"
INFLUXDB_ORG="greenpulse"
INFLUXDB_BUCKET="energy_data"

# Server
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ML Service
ML_SERVICE_URL=http://localhost:8000

# MQTT Broker
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# External APIs
WEATHER_API_KEY=your-openweathermap-api-key
CARBON_INTENSITY_API_KEY=your-carbon-intensity-api-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Caching
CACHE_TTL_SECONDS=60
READINGS_CACHE_TTL=30

# Background Jobs
BULLMQ_REDIS_URL=redis://localhost:6379
JOB_CONCURRENCY=5

# Logging
LOG_LEVEL=info

# Alerts
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=your-smtp-password
ALERT_FROM_EMAIL=alerts@greenpulse.com

# Slack Integration (optional)
SLACK_WEBHOOK_URL=
